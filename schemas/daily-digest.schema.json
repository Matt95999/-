{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DailyDigest",
  "type": "object",
  "required": ["daily_brief_title", "topline_summary", "coverage_board", "product_sections", "story_items", "watchlist", "generated_at"],
  "properties": {
    "daily_brief_title": { "type": "string" },
    "topline_summary": { "type": "string" },
    "coverage_board": { "type": "array", "items": { "type": "object" } },
    "covered_products": { "type": "array", "items": { "type": "string" } },
    "missing_products": { "type": "array", "items": { "type": "object" } },
    "product_sections": { "type": "array", "items": { "type": "object" } },
    "story_items": { "type": "array", "items": { "type": "object" } },
    "cross_product_connections": { "type": "array", "items": { "type": "string" } },
    "watchlist": { "type": "array", "items": { "type": "string" } },
    "generated_at": { "type": "string" }
  }
}
