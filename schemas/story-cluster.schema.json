{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StoryCluster",
  "type": "object",
  "required": ["story_id", "theme", "articles", "score", "confidence", "cross_links", "product_ids"],
  "properties": {
    "story_id": { "type": "string" },
    "theme": { "type": "string" },
    "articles": { "type": "array", "items": { "type": "object" } },
    "score": { "type": "number" },
    "confidence": { "type": "number" },
    "cross_links": { "type": "array", "items": { "type": "string" } },
    "vendor_ids": { "type": "array", "items": { "type": "string" } },
    "product_ids": { "type": "array", "items": { "type": "string" } },
    "sub_product_ids": { "type": "array", "items": { "type": "string" } },
    "primary_product_id": { "type": ["string", "null"] },
    "primary_sub_product_id": { "type": ["string", "null"] },
    "official_source_level": { "type": "string" },
    "primary_language": { "type": "string" }
  }
}
