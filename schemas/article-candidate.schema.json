{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ArticleCandidate",
  "type": "object",
  "required": ["source_name", "source_type", "source_id", "source_role", "url", "title", "discovered_at", "signals", "confidence", "content_hash"],
  "properties": {
    "source_name": { "type": "string" },
    "source_type": { "type": "string" },
    "source_id": { "type": "string" },
    "source_role": { "type": "string" },
    "source_status": { "type": "string" },
    "vendor_id": { "type": "string" },
    "product_ids": { "type": "array", "items": { "type": "string" } },
    "sub_product_ids": { "type": "array", "items": { "type": "string" } },
    "url": { "type": "string" },
    "title": { "type": "string" },
    "published_at": { "type": ["string", "null"] },
    "discovered_at": { "type": "string" },
    "full_text": { "type": ["string", "null"] },
    "excerpt": { "type": ["string", "null"] },
    "language": { "type": "string" },
    "signals": { "type": "object" },
    "confidence": { "type": "number" },
    "content_hash": { "type": "string" }
  }
}
